# Miniflux Configuration
# Generated by xCloud OneClick Template Engine

# --- Database connection ---
# Constructed against the in-network postgres sidecar; sslmode=disable because
# the official postgres image doesn't ship TLS by default (in-network only).
DATABASE_URL=postgres://miniflux:${DB_PASSWORD}@db:5432/miniflux?sslmode=disable

# --- App listener ---
LISTEN_ADDR=0.0.0.0:8080

# --- Public-facing URL ---
# Required for cookie scope and absolute link generation in OAuth redirects,
# email-from-feeds, and the sitemap. Must match the public URL even though
# nginx terminates TLS upstream.
BASE_URL=https://${DOMAIN}

# --- One-shot bootstrap (idempotent — safe to leave at 1 forever) ---
# RUN_MIGRATIONS: applies any pending schema migrations on boot. No-op when up to date.
# CREATE_ADMIN: creates the admin user on first boot. No-op on subsequent boots
#   (logs "Skipping admin user creation because it already exists").
RUN_MIGRATIONS=1
CREATE_ADMIN=1
ADMIN_USERNAME=${ADMIN_USER}
ADMIN_PASSWORD=${ADMIN_PASSWORD}

# --- Postgres sidecar (consumed by the db service via env_file) ---
POSTGRES_USER=miniflux
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=miniflux

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
