# Gotify Configuration
# Generated by xCloud OneClick Template Engine

# --- Server binding ---
# Gotify listens on this port inside the container; nginx proxies external traffic.
GOTIFY_SERVER_PORT=80

# --- Database (SQLite default; lives on the gotify_data named volume) ---
# Path is relative to /app (the container's WORKDIR), so this resolves to
# /app/data/gotify.db, which sits on the mounted volume.
GOTIFY_DATABASE_DIALECT=sqlite3
GOTIFY_DATABASE_CONNECTION=data/gotify.db

# --- Initial admin (consumed only on first boot — change via UI afterward) ---
GOTIFY_DEFAULTUSER_NAME=${ADMIN_USER}
GOTIFY_DEFAULTUSER_PASS=${ADMIN_PASSWORD}

# --- Registration / password policy ---
# Public sign-up is disabled. Admin invites users from the dashboard.
GOTIFY_REGISTRATION=false
# bcrypt cost factor (10 = ~100ms hash on modern CPUs).
GOTIFY_PASSSTRENGTH=10

# --- Uploaded image storage (notification icons) ---
GOTIFY_UPLOADEDIMAGESDIR=data/images

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
