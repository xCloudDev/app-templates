# Memos Configuration
# Generated by xCloud OneClick Template Engine

# --- Server binding ---
# Memos listens on this port inside the container; nginx proxies external traffic.
MEMOS_PORT=5230

# --- Storage driver (SQLite — no external DB needed) ---
MEMOS_DRIVER=sqlite

# --- Data directory (SQLite DB + uploaded blobs) ---
# Single path lives on the memos_data named volume.
MEMOS_DATA=/var/opt/memos

# --- Public-facing URL ---
# Used for OAuth callbacks, share URLs, and reverse-proxy aware redirects.
MEMOS_INSTANCE_URL=https://${DOMAIN}

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
