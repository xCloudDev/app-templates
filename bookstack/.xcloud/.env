# BookStack Configuration
# Generated by xCloud OneClick Template Engine

APP_KEY=${APP_KEY}

# --- Application ---
APP_URL=https://${DOMAIN}
APP_ENV=production
APP_DEBUG=false

# --- Reverse proxy awareness (xCloud's nginx terminates TLS in front of us) ---
APP_PROXIES=*

# --- Database ---
DB_HOST=db
DB_PORT=3306
DB_DATABASE=${DB_NAME}
DB_USERNAME=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}

# --- linuxserver-image conventions ---
PUID=1000
PGID=1000
TZ=UTC

# --- MariaDB sidecar (consumed by the db service via env_file) ---
MYSQL_ROOT_PASSWORD=${DB_ROOT_PASSWORD}
MYSQL_DATABASE=${DB_NAME}
MYSQL_USER=${DB_USER}
MYSQL_PASSWORD=${DB_PASSWORD}

# --- Outbound email (post-install configuration; needed for password reset, invites) ---
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=
MAIL_FROM_NAME=BookStack

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
