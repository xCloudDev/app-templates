# Lychee Configuration
# Generated by xCloud OneClick Template Engine

# --- Application identity ---
APP_NAME=Lychee
APP_ENV=production
APP_DEBUG=false

# APP_KEY required — Lychee's entrypoint validates this on every boot and
# refuses to start without it. Generated as base64:<32 bytes> by xCloud.
APP_KEY=${APP_KEY}

APP_URL=https://${DOMAIN}
APP_TIMEZONE=UTC

# --- Reverse proxy awareness (xCloud's nginx terminates TLS in front of us) ---
TRUSTED_PROXIES=*

# --- Database (SQLite — single-file, lives on the lychee_conf volume) ---
DB_CONNECTION=sqlite

# --- Cache / sessions / queue (file-backed; no Redis sidecar) ---
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
LOG_CHANNEL=daily
LOG_LEVEL=warning

# --- Image processing pipeline ---
IMAGE_DRIVER=imagick

# --- linuxserver-style UID/GID ownership for the mounted volumes ---
PUID=1000
PGID=1000

# --- Initial admin (consumed by Lychee's first-boot setup script) ---
ADMIN_USER=${ADMIN_USER}
ADMIN_PASSWORD=${ADMIN_PASSWORD}

# --- Mail keys are intentionally omitted: Lychee's upstream compose comments
# them out, and the app does not validate empty SMTP at boot. To enable email
# (password reset, share notifications) add MAIL_MAILER=smtp + the standard
# Laravel MAIL_HOST / MAIL_PORT / MAIL_USERNAME / MAIL_PASSWORD / MAIL_FROM_*
# block to this file post-install, then `docker compose up -d`.

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
