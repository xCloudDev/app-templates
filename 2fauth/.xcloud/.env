# 2FAuth Configuration
# Generated by xCloud OneClick Template Engine

# --- Application identity ---
APP_NAME=2FAuth
APP_ENV=production
APP_DEBUG=false

# 32-character key used for cookie encryption AND (when enabled) per-user TOTP-secret encryption.
# 2FAuth's APP_KEY is a raw 32-char string — NOT Laravel's base64:<...> format.
# Losing this value invalidates active sessions and, if account encryption is on, the stored 2FA secrets.
APP_KEY=${APP_KEY}

APP_URL=https://${DOMAIN}
APP_TIMEZONE=UTC

# --- Reverse proxy awareness (xCloud's nginx terminates TLS in front of us) ---
TRUSTED_PROXIES=*

# --- Database (SQLite — single-file, lives on the persistent volume) ---
DB_CONNECTION=sqlite
DB_DATABASE=/2fauth/database.sqlite

# --- Caching / sessions / queue (file-backed; no external services needed) ---
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=12000
QUEUE_CONNECTION=sync
LOG_CHANNEL=daily
LOG_LEVEL=warning

# --- Mail ---
# Default to log driver so the container boots without SMTP config.
# Replace MAIL_MAILER=log with smtp + the MAIL_HOST/MAIL_PORT/MAIL_USERNAME/MAIL_PASSWORD/
# MAIL_FROM_ADDRESS keys post-install when you want password-reset / WebAuthn email flows.
MAIL_MAILER=log

# --- WebAuthn (left at sane defaults; override only if behind a non-https origin) ---
WEBAUTHN_NAME=2FAuth
WEBAUTHN_ID=
WEBAUTHN_HOMEPAGE=https://${DOMAIN}

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
