# Vaultwarden Configuration
# Generated by xCloud OneClick Template Engine

# --- Public-facing URL — required for WebAuthn, email links, attachments ---
DOMAIN=https://${DOMAIN}

# --- /admin panel access ---
# Plain-text token for v1; rotate to an Argon2 hash post-install via:
#   docker compose exec vaultwarden /vaultwarden hash
# then replace the value here and `docker compose up -d`.
ADMIN_TOKEN=${ADMIN_TOKEN}

# --- Signup policy ---
# Default: allow first signup so the admin can create their account, then lock down.
SIGNUPS_ALLOWED=true
SIGNUPS_VERIFY=false
INVITATIONS_ALLOWED=true

# --- Live sync (WebSocket on the same HTTP port since v1.29) ---
WEBSOCKET_ENABLED=true

LOG_LEVEL=warn
SHOW_PASSWORD_HINT=false

# xCloud context exposed for compose interpolation
SITE_NAME=${SITE_NAME}
PORT_MAIN=${PORT_MAIN}
